
# Google Analytics 4 — paste your Measurement ID (starts with G-)
NEXT_PUBLIC_GA_ID=

# Resend — wholesale enquiry form (https://resend.com)
RESEND_API_KEY=
# Where enquiries are delivered (defaults to info@rmmangoes.co.uk)
WHOLESALE_TO_EMAIL=
# Verified sender, e.g. "RM Mangoes <hello@rmmangoes.co.uk>" (defaults to Resend's onboarding sender)
WHOLESALE_FROM_EMAIL=

# ── Site ─────────────────────────────────────────────────────────────────────
# Absolute base URL, used to build Stripe success/cancel redirects.
NEXT_PUBLIC_SITE_URL=https://rmmangoes.co.uk

# ── Supabase ─────────────────────────────────────────────────────────────────
# Public (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Secret (server only — NEVER expose). Dashboard → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ───────────────────────────────────────────────────────────────────
# Public (safe to expose in the browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Secret (server only — NEVER expose)
STRIPE_SECRET_KEY=
# Webhook signing secret (Dashboard → Developers → Webhooks → endpoint)
STRIPE_WEBHOOK_SECRET=

# ── Admin dashboard ──────────────────────────────────────────────────────────
# Password gate for /admin (choose a strong value)
ADMIN_PASSWORD=

# ── Address lookup (optional) ───────────────────────────────────────────────
# Ideal Postcodes (https://ideal-postcodes.co.uk) — powers "type your postcode,
# pick your address" at checkout. Leave blank and checkout still works fine;
# customers just type their address manually instead.
IDEAL_POSTCODES_API_KEY=
